{
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "BUN=$(command -v bun 2>/dev/null || echo \"$HOME/.bun/bin/bun\") && \"$BUN\" run \"${CLAUDE_PLUGIN_ROOT}/dist/hook-handler.js\" 2>/dev/null || node \"${CLAUDE_PLUGIN_ROOT}/dist/hook-handler.js\"",
            "timeout": 5
          }
        ]
      }
    ],
